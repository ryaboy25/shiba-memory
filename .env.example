# Shiba Memory — Configuration
# Copy to .env and customize

# ── Database ────────────────────────────────────────────────────
SHB_DB_HOST=localhost
SHB_DB_PORT=5432
SHB_DB_NAME=shb
SHB_DB_USER=shb
SHB_DB_PASSWORD=shb_dev_password

# ── Embedding Provider ──────────────────────────────────────────
# Options: 'ollama', 'tei', 'openai'
#
# ollama   — Easiest setup. Runs locally, no API key.
#            Best for getting started.
#
# tei      — Sentence-transformers via embed_server.py (GPU-accelerated).
#            Best quality + speed for local GPU setups.
#            See tools/embed_server.py for the lightweight server.
#
# openai   — OpenAI API. Requires API key.
#            Best if you don't have a local GPU.
#
SHB_EMBEDDING_PROVIDER=ollama

# Embedding dimensions (must match your model)
# nomic-embed-text: 768 (padded to 1024)
# mxbai-embed-large-v1: 1024 (native)
# text-embedding-3-small: 1536 (or set dimensions param)
SHB_EMBED_DIMENSIONS=1024

# Embedding timeout and retries
# SHB_EMBED_TIMEOUT_MS=10000
# SHB_EMBED_RETRIES=2

# Fallback provider (used if primary fails)
# SHB_EMBEDDING_FALLBACK=ollama

# ── Ollama (default) ───────────────────────────────────────────
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then:    ollama pull nomic-embed-text
SHB_OLLAMA_URL=http://localhost:11434
SHB_OLLAMA_MODEL=nomic-embed-text

# ── TEI / Sentence-Transformers ─────────────────────────────────
# Option A: Use the lightweight embed server (recommended for GPU):
#   pip install sentence-transformers fastapi uvicorn
#   CUDA_VISIBLE_DEVICES=0 uvicorn tools.embed_server:app --port 8090
#
# Option B: HuggingFace TEI Docker (requires compatible GPU compute cap):
#   docker run -d --gpus all -p 8090:80 \
#     ghcr.io/huggingface/text-embeddings-inference:latest \
#     --model-id mixedbread-ai/mxbai-embed-large-v1
#
# SHB_EMBEDDING_PROVIDER=tei
# SHB_TEI_URL=http://localhost:8090

# ── OpenAI ──────────────────────────────────────────────────────
# SHB_EMBEDDING_PROVIDER=openai
# SHB_OPENAI_API_KEY=sk-...
# SHB_OPENAI_MODEL=text-embedding-3-small

# ── LLM Provider (for Tier 2/3 extraction) ──────────────────────
# Options: 'openai-compatible', 'ollama', 'anthropic', 'none'
#
# 'none' is first-class — Shiba works without any LLM.
# Tier 1 patterns still capture memories, search still works,
# ACT-R still scores. You just skip targeted extraction.
#
SHB_LLM_PROVIDER=none

# openai-compatible (works with llama.cpp, vLLM, OpenRouter, etc.)
# SHB_LLM_PROVIDER=openai-compatible
# SHB_LLM_URL=http://localhost:8080
# SHB_LLM_MODEL=gemma-4
# SHB_LLM_API_KEY=
# SHB_LLM_TIMEOUT_MS=15000
# SHB_LLM_RETRIES=1

# ── Gateway API ─────────────────────────────────────────────────
SHB_GATEWAY_PORT=18789
SHB_GATEWAY_HOST=0.0.0.0
# SHB_API_KEY=your-secret-key-here
