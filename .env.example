# CCB - Claude Code Brain Configuration

# Database
CCB_DB_HOST=localhost
CCB_DB_PORT=5432
CCB_DB_NAME=ccb
CCB_DB_USER=ccb
CCB_DB_PASSWORD=ccb_dev_password

# Embedding provider: 'ollama' or 'openai'
CCB_EMBEDDING_PROVIDER=ollama

# Ollama (default — runs locally, no API key needed)
CCB_OLLAMA_URL=http://localhost:11434
CCB_OLLAMA_MODEL=nomic-embed-text

# OpenAI (alternative — requires API key)
# CCB_OPENAI_API_KEY=sk-...
# CCB_OPENAI_MODEL=text-embedding-3-small
